{# stacks/dev wrapper: process-compose dev stack. Set mode + address variables, then #}
{# include the one shared manifest body. The include path resolves from the template's #}
{# `_subdirectory` root (the renderer's loader base), NOT from this file's directory — #}
{# so it is `../../_shared` even though this file sits one level deeper. #}
{% set runtime_mode = "process" %}
{# The OPERATOR owns path-input translation (copierx.ResolvePathInputs): every render #}
{# flow (init, chain, workspace chain, stack update) rewrites a relative `type: path` #}
{# input to be ANGEE_ROOT-relative before this template sees it (logical "examples/x" #}
{# arrives as "../examples/x"; repo-layout "." arrives as ".."), and an absolute input #}
{# arrives verbatim. The template therefore uses both inputs AS-IS — re-translating #}
{# here (the old `../`+input math) double-counted the hop and broke every flow. #}
{% set app_source = project_path %}
{% set framework_source = framework_path %}
{# Repo layout (framework_path arrives as "..") nests the project under the framework, #}
{# so `uv run` finds the framework pyproject (owner of the postgres extra) by walk-up — #}
{# no --project. Any OTHER framework checkout must be passed as an ABSOLUTE path: uv #}
{# resolves --project against each job's workdir (the project root), where an #}
{# ANGEE_ROOT-relative value would point at the wrong directory. #}
{% if framework_path == ".." %}{% set uv_project = "" %}{% else %}{% set uv_project = framework_path %}{% endif %}
{# uv's cache: the framework pyproject pins cache-dir ".angee/caches/uv", which uv #}
{# resolves against the CWD (the job workdir = project root). In the repo layout the #}
{# workdir is the repo root, so that default lands in the repo's gitignored .angee — #}
{# keep it (empty uv_cache_dir = no env override). In a consumer layout the workdir is #}
{# the project root, where the default would mint a stray nested `.angee/`; override #}
{# with the stack-owned, gitignored `caches/uv` under the project root instead. #}
{% if uv_project %}{% set uv_cache_dir = "caches/uv" %}{% else %}{% set uv_cache_dir = "" %}{% endif %}
{# Address variables: process mode reaches postgres/redis/operator on 127.0.0.1:${ports.x} #}
{# and the host gateway (host.docker.internal) where containers must reach the host. #}
{% set database_url = "postgres://angee:${secret.db-password}@127.0.0.1:${ports.postgres}/angee" %}
{% set redis_url = "redis://127.0.0.1:${ports.redis}/0" %}
{% set celery_broker_url = "redis://127.0.0.1:${ports.redis}/1" %}
{% set operator_url = "http://127.0.0.1:${ports.operator}" %}
{% set mcp_url = "http://host.docker.internal:${ports.django}/mcp" %}
{% set operator_bind = "0.0.0.0" %}
{% set pgdata_mount = "./pgdata" %}
{% include "../../_shared/stack-body.yaml.jinja" %}
