version: 1
kind: stack
name: {{ project_name }}
{% set database_url = "postgres://angee:${secret.db-password}@127.0.0.1:${ports.postgres}/angee" %}
{# project_path / framework_path are given relative to the stack dir (the parent of #}
{# ANGEE_ROOT, where `angee init` renders from). The operator resolves a source `path:` #}
{# relative to ANGEE_ROOT itself — one level deeper — so a relative source path is #}
{# `../`+input, and `.` collapses to `..`. Absolute inputs are kept as-is. This is what #}
{# puts working_dir (source://app) at the project root, where manage.py lives, instead #}
{# of inside ANGEE_ROOT. #}
{% if (project_path | first) == "/" %}{% set app_source = project_path %}{% elif project_path == "." %}{% set app_source = ".." %}{% else %}{% set app_source = "../" + project_path %}{% endif %}
{% if (framework_path | first) == "/" %}{% set framework_source = framework_path %}{% elif framework_path == "." %}{% set framework_source = ".." %}{% else %}{% set framework_source = "../" + framework_path %}{% endif %}
{# Every Python job runs with working_dir at the project root. In the repo-level layout #}
{# (framework_path == ".") the framework IS the stack root and the project is nested #}
{# under it, so `uv run` discovers the framework pyproject (which owns the `postgres` #}
{# extra) by walking up — no --project needed. Otherwise the framework is a separate #}
{# checkout, not an ancestor of the project root, so walk-up fails; point uv at it #}
{# explicitly with --project framework_path (the framework as given from the project #}
{# root — a sibling `../angee-django`, or an absolute path). #}
{% if framework_path == "." %}{% set uv_project = "" %}{% else %}{% set uv_project = framework_path %}{% endif %}

template:
  active: stacks/dev
  answers_file: .copier-answers.stack.yml

# Edge ingress. The operator's central Caddy fronts every service that declares a
# `route:` block (e.g. the agent chat WebSocket) and forward-auths each upgrade
# against the operator's /edge/verify. Without an `ingress.type: caddy` stack the
# operator treats routed services as unrouted (ServiceEndpoint.routed = false) and
# `agentChatEndpoint` can't hand the browser a reachable URL.
#
# Dev uses `routing: path` + `tls: off`: one shared host with a `/<service>/` prefix
# per agent (no per-agent subdomain/DNS), and plain ws (no local-CA cert to trust).
# `localhost` always resolves, so a freshly provisioned agent is reachable at
# ws://localhost:<edge_port>/<service>/ with zero DNS or cert setup. Prod flips to the
# defaults (`routing: host`, `tls: auto` → wss://<service>.<domain>/ with a wildcard cert).
ingress:
  type: caddy
  routing: path
  tls: "off"   # quoted: bare YAML `off` is boolean false; the operator wants the string
  domain: localhost
  # Host port the edge publishes. 80 for the base stack; a workspace leases a distinct
  # value (operator.port_pool.edge) so parallel stacks on one host don't all fight for :80.
  # The agent chat URL carries this port (ws://localhost:<port>/<service>/).
  port: {{ edge_port }}
  # The edge runs as a container; this dev stack's operator is `runtime: local`, so
  # forward_auth must reach it on the host instead of the default `operator:9000`.
  verify: host.docker.internal:{{ operator_port }}

# The operator daemon owns stack-secret management. The console bearer is a
# generated secret shared by the daemon (--token) and Django
# (ANGEE_OPERATOR_TOKEN setting), so neither side hardcodes it.
secrets_backend:
  type: env-file
  path: .env

secrets:
  operator-token: { generated: true, length: 32 }
  db-password: { generated: true, length: 32 }

ports:
  django: { value: {{ django_port }}, export_env: DJANGO_PORT }
  process_compose: { value: {{ process_compose_port }}, export_env: PROCESS_COMPOSE_PORT }
  postgres: { value: {{ postgres_port }}, export_env: POSTGRES_PORT }
  # The operator daemon's port — workspace-allocated (operator.port_pool.operator),
  # never a hardcoded 9000. Services reference it as ${ports.operator}.
  operator: { value: {{ operator_port }}, export_env: ANGEE_OPERATOR_PORT }

# Local state angee owns and must guarantee exists before any job runs. Subpaths
# are relative to the stack dir (the parent of {{ ANGEE_ROOT }}); the operator
# materializes them on every bring-up (StackPrepare), so a fresh stack/workspace
# has them before makemigrations/migrate open the database. ANGEE_DATA_DIR
# (settings.yaml) resolves to this same {{ ANGEE_ROOT }}/data — SQLite never
# creates its file's parent directory, so without this the first migrate fails
# with "unable to open database file".
persist:
  app-data: { subpath: {{ ANGEE_ROOT }}/data, scope: stack }
  chrome-profile: { subpath: {{ ANGEE_ROOT }}/data/chrome, scope: stack }
  pgdata: { subpath: {{ ANGEE_ROOT }}/pgdata, scope: stack }

sources:
  app:
    kind: local
    path: {{ app_source }}
  framework:
    kind: local
    path: {{ framework_source }}

# The compose/build/serve lifecycle. JOBS run once in depends_on order; SERVICES
# stay up. Every command boots angee.compose.settings, which reads the project's
# settings contract and resolves the single Django app set. Runtime files are
# emitted only by the explicit build job; normal Django startup checks and
# imports the generated models without writing.
jobs:
  postgres-ready:
    runtime: local
    # Same working_dir as every other Python job: the project root, so `uv run`
    # resolves the framework project (walking up in the repo-level layout, or via
    # --project against it in a per-project layout) and psycopg is importable.
    workdir: source://app
    command:
      - sh
      - "-c"
      - >-
        n=0;
        until uv run{% if uv_project %} --project {{ uv_project }}{% endif %} --extra postgres python -c "import os, psycopg; psycopg.connect(os.environ['DATABASE_URL']).close()" 2>/tmp/pgwait.err; do
        n=$$((n+1));
        [ "$$n" -ge 60 ] && { echo 'postgres not reachable after 60s:' >&2; cat /tmp/pgwait.err >&2; exit 1; };
        echo "waiting for postgres ($$n/60)..."; sleep 1;
        done
    env:
      DATABASE_URL: "{{ database_url }}"

  # Explicit runtime emit. Later jobs and services check/import this output
  # without rewriting it during Django app population.
  build:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "angee", "build"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [postgres-ready]

  # Prune stale package-managed REBAC schema before any check-gated DB step. An
  # addon dropped from INSTALLED_APPS, or a definition removed from a still-composed
  # permissions.zed, leaves rows in the Schema* tables; that fails rebac.E009 and
  # would otherwise block makemigrations / migrate / rebac sync. This check-free
  # reconcile runs first and keeps rebuilds green. See angee.platform.permissions.
  reconcile-permissions:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "reconcile_permissions"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [build]

  # Generate migrations against the freshly emitted concrete models. Mandatory:
  # the composer emits models.py, never migration files. No app list — the set of
  # composed apps is owned by the composer (each redirects to
  # runtime/<label>/migrations via MIGRATION_MODULES); bare makemigrations
  # discovers them, so a new addon never has to be re-listed here.
  makemigrations:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "makemigrations"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [reconcile-permissions]

  migrate:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "migrate", "--noinput"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [makemigrations]

  permissions:
    runtime: local
    workdir: source://app
    # --force-overwrite: in a dev stack the source permissions.zed is the truth —
    # without it, sync skips schema changes as "admin-edited" drift and the
    # running app keeps stale permissions after every zed edit.
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "rebac", "sync", "--yes", "--force-overwrite"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [migrate]

  resources:
    runtime: local
    workdir: source://app
    command:
      - sh
      - "-c"
      - uv run{% if uv_project %} --project {{ uv_project }}{% endif %} --extra postgres python manage.py resources load --include-demo
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [permissions]

  # Render GraphQL SDL to runtime/schemas/<name>.graphql; the SPA imports it to
  # derive its urql cache config.
  schema:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "schema"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    depends_on: [build]

  # Install the JS workspace so the frontend service has its node_modules.
  # Idempotent and fast when the lockfile is already satisfied.
  deps:
    runtime: local
    workdir: source://framework
    command: ["pnpm", "install"]

  # Refresh the operator daemon's committed SDL from the LIVE daemon (the daemon
  # owns its schema; Django introspects it over the shared bearer). The command
  # waits for daemon readiness and fails loudly if the contract can't be fetched,
  # so a stale SDL never silently masks daemon drift. The unified codegen reads
  # this SDL straight from the operator package, so codegen waits on this refresh.
  operator-schema:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "operator_schema"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
      ANGEE_OPERATOR_URL: "http://127.0.0.1:${ports.operator}"
      ANGEE_OPERATOR_TOKEN: "${secret.operator-token}"
    depends_on: [operator, build]

  # Regenerate this project's typed GraphQL operations into runtime/gql/<name>/
  # from the emitted Django SDL and the operator daemon SDL. @angee/app owns the
  # one codegen CLI (the manifest declares the operator as an external schema), so
  # the stack runs a single pass after both schema sources and before Vite.
  codegen:
    runtime: local
    workdir: source://app
    command: ["pnpm", "--dir", "{{ web_path }}", "codegen"]
    depends_on: [deps, schema, operator-schema]

services:
  postgres:
    runtime: container
    image: pgvector/pgvector:pg17
    env:
      POSTGRES_USER: angee
      POSTGRES_DB: angee
      POSTGRES_PASSWORD: "${secret.db-password}"
    mounts:
      # docker-compose.yaml is generated inside {{ ANGEE_ROOT }}, so this relative
      # bind targets the stack's {{ ANGEE_ROOT }}/pgdata directory instead of
      # {{ ANGEE_ROOT }}/{{ ANGEE_ROOT }}/pgdata.
      - bind://./pgdata:/var/lib/postgresql/data
    ports:
      - "${ports.postgres}:5432"

  # Angee overrides `runserver` to serve angee.asgi with uvicorn (keeping the ASGI
  # lifespan the MCP mount's session manager needs — see angee.asgi) under Django's
  # own follow-imports autoreloader. That watches every imported source file —
  # consumer addons, base addons, framework core, and editable deps — with no
  # `--reload-dir` math, and never the generated runtime/ tree (the emit happens
  # during each child's boot, before its reloader snapshots), so a model edit
  # reloads once. The boot also regenerates the GraphQL SDL (Vite then HMRs).
  django:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "runserver", "127.0.0.1:{{ django_port }}"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
      # Django mints the browser's scoped connection token over the daemon's direct
      # URL + the shared generated secret. The browser then opens the daemon GraphQL
      # same-origin via /operator/graphql (the UI proxies /operator → the daemon, so
      # no cross-origin). The operator daemon runs on the workspace-allocated port.
      ANGEE_OPERATOR_GRAPHQL_ENDPOINT: "/operator/graphql"
      ANGEE_OPERATOR_URL: "http://127.0.0.1:${ports.operator}"
      ANGEE_OPERATOR_TOKEN: "${secret.operator-token}"
      # Container-reachable URL for this Django process's built-in /mcp mount.
      # Agents run in containers, so they reach the local backend through the host gateway.
      ANGEE_BUILTIN_MCP_URL: "http://host.docker.internal:{{ django_port }}/mcp"
    after: [resources, schema]

  procrastinate-worker:
    runtime: local
    workdir: source://app
    command: ["uv", "run"{% if uv_project %}, "--project", "{{ uv_project }}"{% endif %}, "--extra", "postgres", "python", "manage.py", "procrastinate", "worker"]
    env:
      ANGEE_PROJECT_DIR: "."
      DATABASE_URL: "{{ database_url }}"
    after: [resources, schema]

  # Vite dev server for the SPA. It proxies /graphql/ and /auth/csrf/ to Django,
  # so the SPA and backend share the session cookie across the two ports. The UI
  # port is the workspace's allocation, so an isolated workspace serves on its own
  # port and the e2e harness (docs/testing/e2e.md) targets the same URL. A project
  # that prebundles the `@angee/*` packages (`prebundleAngeePackages: true`) has
  # `@angee/app/vite` bust the prebundle on any workspace source edit (a source
  # mtime signature drives `optimizeDeps.force`), so a linked `@angee/*` change is
  # never served stale without a manual cache wipe; the in-repo example consumes
  # them as linked source (excluded, HMR) so this never applies here.
  frontend:
    runtime: local
    workdir: source://app
    command: ["pnpm", "--dir", "{{ web_path }}", "dev"]
    env:
      ANGEE_DJANGO_URL: http://127.0.0.1:{{ django_port }}
      ANGEE_UI_PORT: "{{ ui_port }}"
      # The UI proxies /operator/* to the daemon (same-origin → no CORS), the same
      # way it proxies /graphql/ to Django.
      ANGEE_OPERATOR_URL: "http://127.0.0.1:${ports.operator}"
    after: [deps, schema, django, operator, codegen]

  # Storybook component workshop (@angee/storybook), served alongside the SPA. It
  # renders @angee/ui with mocked app/refine fixtures, so it needs only the JS
  # workspace installed — no Django, schema, or operator dependency. The port is
  # the workspace's storybook allocation, so each workspace serves its own.
  storybook:
    runtime: local
    workdir: source://framework
    command: ["pnpm", "--filter", "@angee/storybook", "dev", "--no-open"]
    env:
      STORYBOOK_PORT: "{{ storybook_port }}"
    after: [deps]

  # The operator daemon for THIS stack: it serves the console's data (services,
  # workspaces, sources, gitops, secrets) and is what runs the dev stack.
  # `angee operator --root .` resolves the stack root by walking up to this stack's
  # angee.yaml; binds loopback on the workspace-allocated operator port.
  operator:
    runtime: local
    command:
      - sh
      - "-c"
      # Bind 0.0.0.0 (not just loopback): the Caddy edge runs in a container and
      # reaches the operator's /edge/verify via host.docker.internal, which lands on
      # the host gateway, not 127.0.0.1. 0.0.0.0 still serves Django on loopback.
      - exec angee operator --root . --bind 0.0.0.0 --port ${ports.operator} --token "$ANGEE_OPERATOR_TOKEN"
    env:
      ANGEE_OPERATOR_TOKEN: "${secret.operator-token}"
