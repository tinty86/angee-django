# One service entry appended to the outer stack by `service create`. Routed through
# the operator's central Caddy (see claude-code/service.yaml.jinja) — `route:` replaces
# `ports:`, the operator owns edge auth, and the API key is an operator-held secret.
# The operator renders this stack entry with its own engine (not Python Jinja2/copier),
# which supports only if/elif/else plus simple value interpolation — no `set` tag, string
# concatenation, or inline conditional. Keep it to the constructs claude-code's entry uses.
services:
  {{ service_name }}:
    runtime: container
    build:
      # The operator installs the rendered docker/ at .angee/services/<name>/docker
      # and requires the build context to resolve there.
      context: ./.angee/services/{{ service_name }}/docker
    mounts:
      - "workspace://{{ workspace_name }}:/workspace"
    env:
      # Provider selects the API-key env var; the secret name falls back to
      # "<provider>-api-key" when the caller leaves `secret_name` blank.
{%- if provider == "openai" %}
{%- if secret_name %}
      OPENAI_API_KEY: "${secret.{{ secret_name }}}"
{%- else %}
      OPENAI_API_KEY: "${secret.openai-api-key}"
{%- endif %}
{%- elif provider == "openrouter" %}
{%- if secret_name %}
      OPENROUTER_API_KEY: "${secret.{{ secret_name }}}"
{%- else %}
      OPENROUTER_API_KEY: "${secret.openrouter-api-key}"
{%- endif %}
{%- elif provider == "groq" %}
{%- if secret_name %}
      GROQ_API_KEY: "${secret.{{ secret_name }}}"
{%- else %}
      GROQ_API_KEY: "${secret.groq-api-key}"
{%- endif %}
{%- else %}
{%- if secret_name %}
      ANTHROPIC_API_KEY: "${secret.{{ secret_name }}}"
{%- else %}
      ANTHROPIC_API_KEY: "${secret.anthropic-api-key}"
{%- endif %}
{%- endif %}
{%- if model %}
      OPENCODE_MODEL: "{{ model }}"
      # Load the baked config (model: {env:OPENCODE_MODEL}) so opencode pins this model
      # instead of its own default; opencode does not take the model over the ACP session.
      OPENCODE_CONFIG: "/home/node/.config/opencode/angee.json"
{%- endif %}
    route:
      port: 3007
      auth: forward
