import { schemaCodegen } from "./codegen.shared";

// This project installs its addons under `node_modules`, so it passes its own
// install-layout document roots (sorted, deterministic) rather than relying on
// the `ANGEE_CODEGEN_DOCUMENT_ROOTS` env fallback. To add a schema beyond the
// standard `public`/`console` pair, add a sibling `codegen.<name>.ts` and list
// the schema in package.json's `codegen` script + bin/build-operation-documents.mjs.
export default schemaCodegen("public", [
{%- for root in document_roots | sort %}
  {{ root | tojson }},
{%- endfor %}
]);
