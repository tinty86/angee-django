import type { CodegenConfig } from "@graphql-codegen/cli";

// Per-schema client-preset codegen for this composed Angee project. Each named
// runtime schema prints its own SDL into `runtime/schemas/<name>.graphql`; this
// emits a matching typed `graphql()` document factory + operation/scalar/enum
// types into `runtime/gql/<name>/`.
//
// Schema routing is BY DOCUMENT FILE. client-preset scans the `graphql(...)`
// identifier globally and cannot isolate two schemas by import module (its
// preset ignores `pluckConfig.modules`, and a custom `gqlTagName` is not
// plucked at all), so each run scans a disjoint, schema-pure set of files:
//
//   documents.ts / documents.<schema>.ts  ->  <schema>
//   documents.public.ts                   ->  public
//
// An operation file therefore targets exactly one schema; an addon that uses two
// (e.g. iam login vs admin) keeps a `documents.public.ts` beside its
// `documents.ts`. Each file imports `graphql` from `@angee/gql/<name>` for its
// types. The schema is the *generated* SDL (the one source of truth the app runs
// against), never a hand-maintained copy. Run after SDL emission.

const scalars = {
  DateTime: "string",
  Date: "string",
  BigInt: "string",
  JSON: "unknown",
} as const;

// Roots whose `documents{,.<schema>}.ts` author this project's operations.
// A downstream project installs its addons under `node_modules`, so each
// per-schema config (`codegen.<name>.ts`) passes its OWN install-layout roots
// (e.g. `node_modules/@angee/*/web/src` + `./src` + its consumer addons). When a
// config omits them, the `ANGEE_CODEGEN_DOCUMENT_ROOTS` env var (a list separated
// by the OS path delimiter `:` / `;`, or commas) is used as a fallback. The roots
// are sorted so the glob set is deterministic regardless of supply order.
function documentRootsFromEnv(): string[] | undefined {
  const raw = process.env.ANGEE_CODEGEN_DOCUMENT_ROOTS?.trim();
  if (!raw) return undefined;
  return raw
    .split(/[,;:]/)
    .map((root) => root.trim())
    .filter((root) => root.length > 0);
}

function documentGlobs(name: string, roots: string[]): string[] {
  const files =
    name === "public"
      ? ["documents.public.ts"]
      : ["documents.ts", `documents.${name}.ts`];
  return [...roots]
    .sort()
    .flatMap((root) => files.map((file) => `${root}/**/${file}`));
}

export function schemaCodegen(
  name: string,
  // Effective document roots, highest precedence first: the explicit roots this
  // project's `codegen.<name>.ts` passes, then the `ANGEE_CODEGEN_DOCUMENT_ROOTS`
  // env var.
  documentRoots: string[] = documentRootsFromEnv() ?? [],
): CodegenConfig {
  return {
    schema: `../runtime/schemas/${name}.graphql`,
    documents: documentGlobs(name, documentRoots),
    // Pre-migration (no tagged operations yet) must still emit the factory.
    ignoreNoDocuments: true,
    generates: {
      [`../runtime/gql/${name}/`]: {
        preset: "client",
        presetConfig: { fragmentMasking: false },
        config: {
          scalars,
          enumsAsTypes: true,
          skipTypename: true,
          useTypeImports: true,
        },
      },
    },
  };
}
