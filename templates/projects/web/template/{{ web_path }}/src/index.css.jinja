@import "tailwindcss";
@import "@angee/base/styles.css";

/* Scan the class sources so their utilities are generated into this build. The
   roots mirror the codegen document roots — the same addon web/src trees, so the
   project keeps one source of truth for where its UI source lives. The codegen
   roots are relative to the web package root, but `@source` resolves relative to
   THIS file (`src/index.css`), so each root is rebased one level up (`../`). */
{%- for root in document_roots | sort %}
@source "../{{ root[2:] if root.startswith('./') else root }}";
{%- endfor %}
