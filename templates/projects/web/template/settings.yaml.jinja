SECRET_KEY: {{ project_name }}-dev-key
DEBUG: true
ALLOWED_HOSTS:
  - "*"

# {{ project_title }} composes the Angee base addons as its foundation —
# identity & permissions (iam), tiered data (resources), files (storage),
# connectors (integrate), partners (parties), messaging, OIDC login, platform,
# and the operator console — and adds its own capabilities as consumer addons
# under addons/{{ addon_namespace }}/*.
INSTALLED_APPS:
  - angee.iam
  - angee.resources
  - angee.storage
  - angee.integrate
  - angee.parties
  - angee.messaging
  - angee.iam_integrate_oidc
  - angee.platform
  - angee.operator
  # Consumer addons land here as they are built.
  # - {{ addon_namespace }}.example

ANGEE_ADDON_DIRS:
  - "{BASE_DIR}/addons"
ANGEE_RUNTIME_DIR: "{BASE_DIR}/runtime"
ANGEE_DATA_DIR: "{BASE_DIR}/data"
