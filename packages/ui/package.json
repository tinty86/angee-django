{
  "name": "@angee/ui",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./lib": {
      "types": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./lib/slot-outlet": {
      "types": "./src/lib/slot-outlet.tsx",
      "import": "./src/lib/slot-outlet.tsx"
    },
    "./lib/variant-context": {
      "types": "./src/lib/variant-context.tsx",
      "import": "./src/lib/variant-context.tsx"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "import": "./src/lib/*.ts"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@angee/refine": "workspace:*",
    "@angee/resources": "workspace:*",
    "@angee/sdk": "workspace:*",
    "@base-ui/react": "^1.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
