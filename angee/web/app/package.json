{
  "name": "@angee/app",
  "version": "0.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "bin": {
    "angee-web-codegen": "./bin/angee-web-codegen.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./create-app": {
      "types": "./src/create-app.tsx",
      "import": "./src/create-app.tsx"
    },
    "./define-addon": {
      "types": "./src/define-addon.ts",
      "import": "./src/define-addon.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./testing": {
      "types": "./src/testing.tsx",
      "import": "./src/testing.tsx"
    },
    "./vite": {
      "types": "./config/vite.ts",
      "import": "./config/vite.ts"
    },
    "./vitest": {
      "types": "./config/vitest.ts",
      "import": "./config/vitest.ts"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@angee/logo-react": "^0.2.1",
    "@angee/refine": "workspace:*",
    "@angee/resources": "workspace:*",
    "@angee/ui": "workspace:*",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@refinedev/core": "^5.0.12",
    "graphql": "^16.14.0",
    "nuqs": "^2.5.0"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-router": "^1",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/vite": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
