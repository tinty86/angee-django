     1	"""ASGI application serving GraphQL over HTTP and WebSockets.
     2	
     3	HTTP requests are handled by the Django ASGI app, so they pass through Django
     4	middleware and reach the ``graphql/<name>/`` views in ``angee.base.urls``.
     5	WebSocket connections for each contributed schema are routed to a Strawberry
     6	Channels consumer, one route per schema name. Names are enumerated when the
     7	application is built; serving happens after the runtime is composed, so every
     8	addon ``graphql.py`` is importable at that point.
     9	"""
    10	
    11	from __future__ import annotations
    12	
    13	import re
    14	from typing import Any
    15	
    16	from channels.auth import AuthMiddlewareStack
    17	from channels.routing import ProtocolTypeRouter, URLRouter
    18	from django.core.asgi import get_asgi_application
    19	from django.urls import re_path
    20	from strawberry.channels import GraphQLWSConsumer
    21	
    22	from angee.base.graphql.schema import build_schema, collect_schema_names
    23	from angee.base.graphql.subscriptions import scope_actor
    24	
    25	
    26	class AngeeGraphQLWSConsumer(GraphQLWSConsumer[dict[str, object], None]):
    27	    """GraphQL WebSocket consumer that resolves the REBAC actor on connect.
    28	
    29	    HTTP requests get their actor from ``rebac.middleware.ActorMiddleware``;
    30	    WebSocket connections bypass Django middleware, so the connection actor is
    31	    resolved from the channels scope and attached to the GraphQL context for
    32	    subscription read-gating.
    33	    """
    34	
    35	    async def get_context(
    36	        self, request: Any, response: Any
    37	    ) -> dict[str, object]:
    38	        context = await super().get_context(request, response)
    39	        context["actor"] = scope_actor(self.scope)
    40	        return context
    41	
    42	
    43	def build_application() -> ProtocolTypeRouter:
    44	    """Return an ASGI app serving GraphQL over HTTP and WebSockets."""
    45	
    46	    django_asgi_app = get_asgi_application()
    47	    websocket_routes = [
    48	        re_path(
    49	            rf"^graphql/{re.escape(name)}/$",
    50	            AngeeGraphQLWSConsumer.as_asgi(schema=build_schema(name)),
    51	        )
    52	        for name in collect_schema_names()
    53	    ]
    54	    return ProtocolTypeRouter(
    55	        {
    56	            "http": django_asgi_app,
    57	            "websocket": AuthMiddlewareStack(URLRouter(websocket_routes)),
    58	        }
    59	    )

