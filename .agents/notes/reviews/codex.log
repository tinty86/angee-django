     1	"""History, revisions, and delete-preview on the composed notes addon."""
     2	
     3	from __future__ import annotations
     4	
     5	import reversion
     6	from django.apps import apps
     7	from django.contrib.auth import get_user_model
     8	from django.core.management import call_command
     9	from django.test import TransactionTestCase
    10	from rebac import actor_context, system_context, to_subject_ref
    11	
    12	from angee.base.graphql import build_schema
    13	
    14	Note = apps.get_model("notes", "Note")
    15	User = get_user_model()
    16	
    17	
    18	class NotesVersioningTests(TransactionTestCase):
    19	    """Audit history, body revisions, and cascade-previewing deletes."""
    20	
    21	    def setUp(self) -> None:
    22	        call_command("rebac", "sync", verbosity=0)
    23	        with system_context(reason="test-setup"):
    24	            self.user = User.objects.create(
    25	                username="ed", email="ed@example.com", password="!"
    26	            )
    27	            self.note = Note(title="Draft", body="v1", created_by=self.user)
    28	            self.note.save()
    29	
    30	    def test_history_records_each_change(self) -> None:
    31	        with system_context(reason="test"):
    32	            self.note.title = "Final"
    33	            self.note.save()
    34	        self.assertEqual(self.note.history.count(), 2)
    35	        self.assertEqual(self.note.history.first().title, "Final")
    36	
    37	    def test_body_revisions_version_and_revert(self) -> None:
    38	        with system_context(reason="test"):
    39	            with reversion.create_revision():
    40	                self.note.body = "v1"
    41	                self.note.save()
    42	            with reversion.create_revision():
    43	                self.note.body = "v2"
    44	                self.note.save()
    45	
    46	            self.assertEqual(self.note.revisions.count(), 2)
    47	            self.note.revert_to(self.note.revisions.last())
    48	            self.note.refresh_from_db()
    49	
    50	        self.assertEqual(self.note.body, "v1")
    51	
    52	    def test_delete_returns_a_cascade_preview(self) -> None:
    53	        query = (
    54	            "mutation($id: ID!){ deleteNote(id: $id){ "
    55	            "totalDeletedCount hasBlockers deleted { label count } } }"
    56	        )
    57	        with actor_context(to_subject_ref(self.user)):
    58	            result = build_schema("console").execute_sync(
    59	                query, variable_values={"id": self.note.sqid}
    60	            )
    61	
    62	        self.assertIsNone(result.errors)
    63	        self.assertEqual(result.data["deleteNote"]["totalDeletedCount"], 1)
    64	        self.assertFalse(result.data["deleteNote"]["hasBlockers"])
    65	        with system_context(reason="test"):
    66	            self.assertFalse(
    67	                Note.objects.filter(sqid=self.note.sqid).exists()
    68	            )

