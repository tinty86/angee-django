     1	"""Guard the one-way dependency direction of the base addon.
     2	
     3	The build package (``angee.base.compose``) emits the runtime; nothing on the
     4	runtime/serving path may import it. Discovery is the shared primitive and must
     5	stay free of higher layers.
     6	"""
     7	
     8	from __future__ import annotations
     9	
    10	import ast
    11	from pathlib import Path
    12	
    13	BASE = Path(__file__).resolve().parents[1] / "src" / "angee" / "base"
    14	
    15	
    16	def _module_imports(path: Path) -> set[str]:
    17	    """Return every dotted module name imported by one source file."""
    18	
    19	    tree = ast.parse(path.read_text(encoding="utf-8"))
    20	    names: set[str] = set()
    21	    for node in ast.walk(tree):
    22	        if isinstance(node, ast.Import):
    23	            names.update(alias.name for alias in node.names)
    24	        elif isinstance(node, ast.ImportFrom) and node.module:
    25	            names.add(node.module)
    26	    return names
    27	
    28	
    29	def _tree_imports(root: Path) -> set[str]:
    30	    """Return the union of imports across a package subtree."""
    31	
    32	    names: set[str] = set()
    33	    for path in root.rglob("*.py"):
    34	        names |= _module_imports(path)
    35	    return names
    36	
    37	
    38	def test_graphql_does_not_import_compose() -> None:
    39	    imports = _tree_imports(BASE / "graphql")
    40	    assert not any(name.startswith("angee.base.compose") for name in imports)
    41	
    42	
    43	def test_resources_does_not_import_compose() -> None:
    44	    imports = _tree_imports(BASE / "resources")
    45	    assert not any(name.startswith("angee.base.compose") for name in imports)
    46	
    47	
    48	def test_serving_does_not_import_compose() -> None:
    49	    imports = _module_imports(BASE / "asgi.py")
    50	    imports |= _module_imports(BASE / "urls.py")
    51	    assert not any(name.startswith("angee.base.compose") for name in imports)
    52	
    53	
    54	def test_discovery_depends_only_on_apps() -> None:
    55	    imports = _module_imports(BASE / "discovery.py")
    56	    internal = {name for name in imports if name.startswith("angee.base")}
    57	    assert internal <= {"angee.base.apps"}

