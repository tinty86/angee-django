     1	"""Order resource entries by their declared ``depends_on`` edges."""
     2	
     3	from __future__ import annotations
     4	
     5	from collections import defaultdict
     6	from collections.abc import Sequence
     7	
     8	from angee.base.resources.entries import ResourceEntry, ResourceLoadError
     9	
    10	EntryKey = tuple[str, str]
    11	
    12	
    13	def order_entries(
    14	    entries: Sequence[ResourceEntry],
    15	) -> tuple[ResourceEntry, ...]:
    16	    """Return entries in load order, honoring ``depends_on``.
    17	
    18	    Each entry is keyed by ``(addon name, source)``. A ``depends_on`` item
    19	    targets ``<source>`` in the same addon, or ``<addon>:<source>`` to cross
    20	    addons. Unknown or unselected targets and dependency cycles raise
    21	    ``ResourceLoadError``. Entries with no edges keep their original order.
    22	    """
    23	
    24	    by_key: dict[EntryKey, ResourceEntry] = {}
    25	    position: dict[EntryKey, int] = {}
    26	    addon_names: dict[str, str] = {}
    27	    for index, entry in enumerate(entries):
    28	        key = _entry_key(entry)
    29	        if key in by_key:
    30	            raise ResourceLoadError(
    31	                f"duplicate resource entry {entry.display}"
    32	            )
    33	        by_key[key] = entry
    34	        position[key] = index
    35	        addon_names[entry.addon.name] = entry.addon.name
    36	        addon_names[entry.addon.label] = entry.addon.name
    37	
    38	    outgoing: dict[EntryKey, list[EntryKey]] = defaultdict(list)
    39	    indegree: dict[EntryKey, int] = {key: 0 for key in by_key}
    40	    for key, entry in by_key.items():
    41	        for dependency in entry.depends_on:
    42	            dependency_key = _dependency_key(entry, dependency, addon_names)
    43	            if dependency_key not in by_key:
    44	                raise ResourceLoadError(
    45	                    f"{entry.display}: depends_on target not selected: "
    46	                    f"{dependency}"
    47	                )
    48	            outgoing[dependency_key].append(key)
    49	            indegree[key] += 1
    50	
    51	    ready = sorted(
    52	        (key for key, count in indegree.items() if count == 0),
    53	        key=position.__getitem__,
    54	    )
    55	    ordered: list[ResourceEntry] = []
    56	    while ready:
    57	        key = ready.pop(0)
    58	        ordered.append(by_key[key])
    59	        for child in sorted(outgoing[key], key=position.__getitem__):
    60	            indegree[child] -= 1
    61	            if indegree[child] == 0:
    62	                ready.append(child)
    63	        ready.sort(key=position.__getitem__)
    64	    if len(ordered) != len(by_key):
    65	        raise ResourceLoadError("cycle detected in resource depends_on")
    66	    return tuple(ordered)
    67	
    68	
    69	def _entry_key(entry: ResourceEntry) -> EntryKey:
    70	    """Return the ``(addon, source)`` key for one entry."""
    71	
    72	    return (entry.addon.name, entry.source)
    73	
    74	
    75	def _dependency_key(
    76	    entry: ResourceEntry,
    77	    dependency: str,
    78	    addon_names: dict[str, str],
    79	) -> EntryKey:
    80	    """Return the key a ``depends_on`` item points at.
    81	
    82	    ``addon_names`` maps every selected addon's name and label to its full
    83	    name, so a cross-addon ``<addon>:<source>`` reference resolves by either.
    84	    """
    85	
    86	    if ":" in dependency:
    87	        addon_ref, source = dependency.split(":", 1)
    88	        return (addon_names.get(addon_ref, addon_ref), source)
    89	    return (entry.addon.name, dependency)

