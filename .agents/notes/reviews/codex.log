   108	    ledger = (
   109	        _ledger_manager()
   110	        .filter(xref=xref)
   111	        .filter(
   112	            Q(source_addon=addon_ref)
   113	            | Q(source_addon__endswith=f".{addon_ref}")
   114	        )
   115	        .exclude(target_id="")
   116	        .order_by("source_addon", "source_path", "target_model", "pk")
   117	        .first()
   118	    )
   119	    if ledger is None:
   120	        raise ValueError(f"unresolved xref {value!r}")
   121	    model = _model_from_label(str(getattr(ledger, "target_model")))
   122	    target = _instance_from_public_id(model, str(getattr(ledger, "target_id")))
   123	    if target is None:
   124	        raise ValueError(f"xref {value!r} has no ORM target")
   125	    return target
