     1	"""Ownership relationships for notes, derived from the acting user.
     2	
     3	Creating a note stamps the actor as ``created_by`` and grants them the
     4	``owner`` relation on ``notes/note``; deleting a note clears its relationships.
     5	Owner grants are what make a note readable and writable by its creator under
     6	the permission schema, so they are wired to the model lifecycle rather than
     7	left to callers.
     8	"""
     9	
    10	from __future__ import annotations
    11	
    12	from typing import Any
    13	
    14	from django.db.models import Model
    15	from django.db.models.signals import post_delete, post_save, pre_save
    16	from rebac import (
    17	    ObjectRef,
    18	    RelationshipTuple,
    19	    SubjectRef,
    20	    current_actor,
    21	    delete_relationships,
    22	    write_relationships,
    23	)
    24	from rebac.types import RelationshipFilter
    25	
    26	RESOURCE_TYPE = "notes/note"
    27	USER_TYPE = "auth/user"
    28	
    29	
    30	def connect() -> None:
    31	    """Wire note ownership to the note lifecycle (idempotent)."""
    32	
    33	    pre_save.connect(stamp_creator, dispatch_uid="notes.stamp_creator")
    34	    post_save.connect(grant_owner, dispatch_uid="notes.grant_owner")
    35	    post_delete.connect(clear_relationships, dispatch_uid="notes.clear")
    36	
    37	
    38	def stamp_creator(
    39	    sender: type[Model], instance: Model, raw: bool = False, **_: Any
    40	) -> None:
    41	    """Record the acting user as the creator of a new note."""
    42	
    43	    if raw or not _is_note(sender) or instance.pk is not None:
    44	        return
    45	    if getattr(instance, "created_by_id", None) is not None:
    46	        return
    47	    actor = current_actor()
    48	    if actor is not None and actor.subject_type == USER_TYPE:
    49	        instance.created_by_id = actor.subject_id
    50	
    51	
    52	def grant_owner(
    53	    sender: type[Model],
    54	    instance: Model,
    55	    created: bool = False,
    56	    raw: bool = False,
    57	    **_: Any,
    58	) -> None:
    59	    """Grant the creator the ``owner`` relation on a new note."""
    60	
    61	    if raw or not created or not _is_note(sender):
    62	        return
    63	    owner_id = getattr(instance, "created_by_id", None)
    64	    if owner_id is None:
    65	        return
    66	    write_relationships(
    67	        [
    68	            RelationshipTuple(
    69	                resource=ObjectRef(RESOURCE_TYPE, str(instance.sqid)),
    70	                relation="owner",
    71	                subject=SubjectRef.of(USER_TYPE, str(owner_id)),
    72	            )
    73	        ]
    74	    )
    75	
    76	
    77	def clear_relationships(
    78	    sender: type[Model], instance: Model, **_: Any
    79	) -> None:
    80	    """Drop every relationship pointing at a deleted note."""
    81	
    82	    if not _is_note(sender):
    83	        return
    84	    delete_relationships(
    85	        RelationshipFilter(
    86	            resource_type=RESOURCE_TYPE,
    87	            resource_id=str(instance.sqid),
    88	        )
    89	    )
    90	
    91	
    92	def _is_note(sender: type[Model]) -> bool:
    93	    """Return true for the composed ``notes.Note`` model."""
    94	
    95	    return sender._meta.label_lower == "notes.note"

