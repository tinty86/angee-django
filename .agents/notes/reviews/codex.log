    16	
    17	def fetch_url(url: str) -> Path:
    18	    """Return a cached local path for ``url``, downloading it once.
    19	
    20	    Only ``http``/``https`` are permitted. Content is cached by a hash of the
    21	    URL under ``ANGEE_DATA_DIR/resource-cache`` with the source suffix
    22	    preserved so format detection still works; an existing cache entry is
    23	    reused without re-fetching.
    24	    """
    25	
    26	    parsed = urlparse(url)
    27	    if parsed.scheme not in ALLOWED_SCHEMES:
    28	        raise ResourceLoadError(
    29	            f"{url!r}: only http/https resource URLs are allowed"
    30	        )
    31	    cache_path = _cache_path(url, parsed.path)
    32	    if cache_path.exists():
    33	        return cache_path
    34	    cache_path.parent.mkdir(parents=True, exist_ok=True)
    35	    request = urllib.request.Request(url, method="GET")
    36	    try:
    37	        with urllib.request.urlopen(request) as response:  # noqa: S310 — scheme checked above
    38	            payload = response.read()
    39	    except OSError as exc:
    40	        raise ResourceLoadError(f"{url!r}: fetch failed: {exc}") from exc
    41	    cache_path.write_bytes(payload)
    42	    return cache_path
    43	
    44	
    45	def _cache_path(url: str, url_path: str) -> Path:
    46	    """Return the content-addressed cache path for one URL."""
    47	
    48	    digest = hashlib.sha256(url.encode("utf-8")).hexdigest()
    49	    suffix = PurePosixPath(url_path).suffix.lower()
    50	    cache_dir = Path(settings.ANGEE_DATA_DIR) / "resource-cache"
    51	    return cache_dir / f"{digest}{suffix}"

