dependencies = [
  "channels>=4.0",
  "daphne>=4.0",
  "django-import-export>=4.3",
  "django-reversion>=5.1",
  "django-simple-history>=3.7",
  "django-sqids>=0.1",
  "django-zed-rebac[strawberry-django]>=0.9.0",
  "django>=6.0",
  "pyyaml>=6",
  "strawberry-graphql>=0.270",
  "strawberry-graphql-django>=0.86",
  "tablib>=3",
]

[dependency-groups]
dev = [
  "mypy>=1.10",
  "pytest>=8.0",
  "pytest-django>=4.8",
  "ruff>=0.15.12",
]

[tool.hatch.build.targets.wheel]
packages = ["src/angee"]
artifacts = [
  "src/angee/**/*.csv",
  "src/angee/**/*.pyi",
  "src/angee/**/*.typed",
  "src/angee/**/*.yaml",
  "src/angee/**/*.yml",
  "src/angee/**/*.zed",
]

[tool.hatch.build.targets.sdist]
only-include = [
  "AGENTS.md",
  "docs",
  "examples",
  "pyproject.toml",
  "src",
  "tests",
  "uv.lock",
]

[tool.pytest.ini_options]
cache_dir = ".pytest_cache"
DJANGO_SETTINGS_MODULE = "tests.settings"
python_files = ["test_*.py"]
testpaths = ["tests", "src/angee/base/resources/tests"]
pythonpath = [".", "src", "examples/notes-angee/src"]
addopts = "-ra --strict-markers --import-mode=importlib"

[tool.ruff]
line-length = 79
target-version = "py314"
cache-dir = ".ruff_cache"
exclude = [
  ".angee",
  ".git",
  ".mypy_cache",
  ".pytest_cache",
  ".ruff_cache",
  ".venv",
  "node_modules",
]

[tool.ruff.lint]
select = ["E", "F", "I"]

[tool.mypy]
python_version = "3.14"
cache_dir = ".mypy_cache"
explicit_package_bases = true
ignore_missing_imports = true
mypy_path = ["src"]
warn_unused_ignores = true

