     1	"""Authorization behaviour of the composed notes addon.
     2	
     3	These exercise the real runtime model against the permission schema: demo
     4	resources seed users and notes, ownership signals grant the creators access,
     5	and field permissions redact owner-only fields from other readers.
     6	"""
     7	
     8	from __future__ import annotations
     9	
    10	from django.apps import apps
    11	from django.contrib.auth import get_user_model
    12	from django.core.management import call_command
    13	from django.test import TransactionTestCase
    14	from rebac import (
    15	    ObjectRef,
    16	    RelationshipTuple,
    17	    SubjectRef,
    18	    system_context,
    19	    write_relationships,
    20	)
    21	from rebac.resources import model_resource_type
    22	
    23	Note = apps.get_model("notes", "Note")
    24	User = get_user_model()
    25	
    26	
    27	class NotesAuthorizationTests(TransactionTestCase):
    28	    """Drive the demo resources through the permission schema."""
    29	
    30	    def setUp(self) -> None:
    31	        call_command("rebac", "sync", verbosity=0)
    32	        call_command(
    33	            "angee_resources", "load", "demo", allow_non_dev=True, verbosity=0
    34	        )
    35	        with system_context(reason="test-setup"):
    36	            self.alice = User.objects.get(username="alice")
    37	            self.bob = User.objects.get(username="bob")
    38	            self.welcome = Note.objects.get(title="Welcome to Angee")
    39	
    40	    def test_note_is_a_rebac_resource(self) -> None:
    41	        self.assertEqual(model_resource_type(Note), "notes/note")
    42	
    43	    def test_demo_load_grants_each_creator_ownership(self) -> None:
    44	        # created_by drives the owner grant: a user reaches only their notes.
    45	        alice_notes = list(Note.objects.as_user(self.alice))
    46	        bob_notes = list(Note.objects.as_user(self.bob))
    47	
    48	        self.assertTrue(alice_notes)
    49	        self.assertTrue(bob_notes)
    50	        self.assertTrue(
    51	            all(note.created_by_id == self.alice.pk for note in alice_notes)
    52	        )
    53	        self.assertTrue(
    54	            all(note.created_by_id == self.bob.pk for note in bob_notes)
    55	        )
    56	        self.assertFalse(
    57	            {note.sqid for note in alice_notes}
    58	            & {note.sqid for note in bob_notes}
    59	        )
    60	
    61	    def test_demo_load_is_idempotent(self) -> None:
    62	        with system_context(reason="test"):
    63	            notes_before = Note.objects.count()
    64	            users_before = User.objects.count()
    65	        call_command(
    66	            "angee_resources", "load", "demo", allow_non_dev=True, verbosity=0
    67	        )
    68	        with system_context(reason="test"):
    69	            self.assertEqual(Note.objects.count(), notes_before)
    70	            self.assertEqual(User.objects.count(), users_before)
    71	
    72	    def test_reader_grant_redacts_owner_only_fields(self) -> None:
    73	        write_relationships(
    74	            [
    75	                RelationshipTuple(
    76	                    resource=ObjectRef("notes/note", self.welcome.sqid),
    77	                    relation="reader",
    78	                    subject=SubjectRef.of("auth/user", str(self.bob.pk)),
    79	                )
    80	            ]
    81	        )
    82	        sqid = self.welcome.sqid
    83	        bob_view = Note.objects.as_user(self.bob).get(sqid=sqid)
    84	        owner_view = Note.objects.as_user(self.alice).get(sqid=sqid)
    85	
    86	        self.assertEqual(bob_view.title, "Welcome to Angee")
    87	        self.assertIsNone(bob_view.is_starred)  # read__is_starred = owner
    88	        self.assertTrue(owner_view.is_starred)
    89	
    90	    def test_deleting_a_note_clears_its_relationships(self) -> None:
    91	        sqid = self.welcome.sqid
    92	        with system_context(reason="test"):
    93	            Note.objects.get(sqid=sqid).delete()
    94	        # The owner can no longer reach the note: its grants were cleared.
    95	        self.assertEqual(
    96	            list(Note.objects.as_user(self.alice).filter(sqid=sqid)), []
    97	        )

