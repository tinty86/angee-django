   436	        if denied:
   437	            sample = ", ".join(sorted(denied)[:5])
   438	            raise PermissionDenied(
   439	                f"Bulk {action}: {len(denied)} row(s) outside actor scope (e.g. {sample}). "
   440	                f"Bulk operations are all-or-nothing."
   441	            )
