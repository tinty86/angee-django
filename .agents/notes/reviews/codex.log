   443	    def _guard_bulk_field_writes(self, actor: SubjectRef, kwargs: dict[str, Any]) -> None:
   444	        """Per-field write enforcement for bulk ``QuerySet.update()``.
   445	
   446	        Mirrors the per-field gate run in ``signals.pre_save``: for each
   447	        ``f`` in ``kwargs`` whose resource type declares a permission
   448	        named ``write__<f>``, every row in the current scope must pass
   449	        that check too — same all-or-nothing semantics as the
   450	        resource-level check. Any denied row aborts the whole update.
   451	
   452	        Backends without an in-process schema accessor (i.e. SpiceDB
   453	        once 0.5 lands) skip this — they'll route per-field checks
   454	        through their own server-side schema. The resource-level
   455	        ``write`` check already ran before we got here.
   456	        """
   457	        from .backends import backend
   458	        from .schema.ast import Schema
   459	        from .schema.walker import field_gated_actions
   460	
   461	        rebac_type = model_resource_type(self.model)
   462	        if not rebac_type:
   463	            return
   464	        accessor = getattr(backend(), "schema", None)
   465	        if not callable(accessor):
   466	            return
   467	        try:
   468	            schema = accessor()
   469	        except Exception:
   470	            return
   471	        if not isinstance(schema, Schema):
   472	            return
   473	        definition = schema.get_definition(rebac_type)
   474	        if definition is None:
   475	            return
   476	        declared = field_gated_actions(definition, "write")
   477	        if not declared:
   478	            return
   479	
   480	        affected = self._affected_resource_ids_for_guard()
   481	        if not affected:
   482	            return
   483	
   484	        meta = self.model._meta
   485	        for raw_name in kwargs.keys():
   486	            # Normalise FK attname → field.name so ``write__folder`` matches
   487	            # an ``update(folder_id=...)`` call.
   488	            try:
   489	                field = meta.get_field(raw_name)
   490	                field_name = field.name
   491	            except Exception:
   492	                field_name = raw_name
   493	            action = f"write__{field_name}"
   494	            if action not in declared:
   495	                continue
   496	            allowed = set(
   497	                accessible_ids(
   498	                    backend(),
   499	                    subject=actor,
   500	                    action=action,
   501	                    resource_type=rebac_type,
   502	                )
   503	            )
   504	            denied = affected - allowed
   505	            if denied:
   506	                sample = ", ".join(sorted(denied)[:5])
   507	                raise PermissionDenied(
   508	                    f"Bulk {action}: {len(denied)} row(s) outside actor scope "
   509	                    f"(e.g. {sample}). Bulk operations are all-or-nothing."
   510	                )
   511	
   512	    def _affected_resource_ids_for_guard(self) -> set[str]:
   513	        """Scan the queryset's target rows without read-scoping the guard itself."""
   514	        attr = resource_id_attr(self.model)
   515	        scan = self.system_context(reason="rebac.bulk-guard")
   516	        return {str(v) for v in scan.values_list(attr, flat=True)}
