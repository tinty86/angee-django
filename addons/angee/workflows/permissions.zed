// Authorization schema for the workflows addon.
// @rebac_package: workflows
// @rebac_package_version: 0.1.0
// @rebac_schema_revision: 1

definition workflows/workflow {
    relation owner: auth/user // rebac:field=created_by
    relation admin: angee/role // rebac:const=admin

    permission create = admin->member
    permission read = owner + admin->member
    permission write = owner + admin->member
    permission delete = owner + admin->member
}

definition workflows/step {
    relation workflow: workflows/workflow // rebac:field=workflow
    relation admin: angee/role // rebac:const=admin

    permission create = workflow->write + admin->member
    permission read = workflow->read + admin->member
    permission write = workflow->write + admin->member
    permission delete = workflow->write + admin->member
}

definition workflows/edge {
    relation workflow: workflows/workflow // rebac:field=workflow
    relation admin: angee/role // rebac:const=admin

    permission create = workflow->write + admin->member
    permission read = workflow->read + admin->member
    permission write = workflow->write + admin->member
    permission delete = workflow->write + admin->member
}

definition workflows/trigger {
    relation workflow: workflows/workflow // rebac:field=workflow
    relation admin: angee/role // rebac:const=admin

    permission create = workflow->write + admin->member
    permission read = workflow->read + admin->member
    permission write = workflow->write + admin->member
    permission delete = workflow->write + admin->member
}
